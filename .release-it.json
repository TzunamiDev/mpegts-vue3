{
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  },
  "git": {
    "commit": false,
    "tag": true,
    "push": true,
    "tagName": "v${version}"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": "pnpm -r --filter='./packages/*' exec npm pkg set version=${version}"
  }
}
